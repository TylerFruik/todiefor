# --- Godot specific ---
.godot/                # The internal cache (re-generated automatically)
*.import               # Optional: Ignores import settings (Godot re-imports on open)
export_presets.cfg     # Prevents sharing your private export/signing keys
.tmp/                  # Temporary files

# --- C# / Mono (if you're using C#) ---
.mono/
bin/
obj/
*.sln
*.csproj

# --- System & Tool specific ---
.DS_Store              # Mac-specific junk
Thumbs.db              # Windows-specific junk
*.log                  # Crash and debug logs
atlassian-ide-plugin.xml
.vscode/               # If you use VS Code (highly recommended to ignore)